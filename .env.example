# هتضيف القيم دي في Render نفسه (Environment tab) مش في ملف هنا فعليًا.
# الملف ده بس عشان تعرف إيه المتغيرات المطلوبة.

# مفتاح Gemini API — هتجيبه مجانًا من https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# اسم الموديل (اختياري، له قيمة افتراضية لو سبته فاضي)
GEMINI_MODEL=gemini-2.0-flash

# مفتاح أو أكتر (مفصولين بفاصلة) — نفس القيمة اللي هتحطها في AGENT_KEY جوه lahza-web.html
AGENT_KEYS=customer1-secret-key
